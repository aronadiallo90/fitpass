# .env.production.example — Copier vers .env sur le VPS et remplir les valeurs
# NE JAMAIS committer ce fichier avec les vraies valeurs

APP_NAME=FitPass
APP_ENV=production
APP_KEY=                    # php artisan key:generate
APP_DEBUG=false             # OBLIGATOIRE false en production
APP_URL=https://fitpass.sn

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily           # Rotation quotidienne des logs
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning           # Pas de debug en prod

# ─── Base de données MySQL 8 ────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fitpass_prod
DB_USERNAME=fitpass_user    # Utilisateur dédié — pas root
DB_PASSWORD=                # Mot de passe fort généré

# ─── Sessions ───────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true        # Chiffrement sessions en prod
SESSION_PATH=/
SESSION_DOMAIN=fitpass.sn
SESSION_SECURE_COOKIE=true  # HTTPS uniquement
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ─── Queue Redis ────────────────────────────────────
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=             # Mot de passe Redis en prod
REDIS_PORT=6379

# ─── Cache Redis ────────────────────────────────────
CACHE_STORE=redis

# ─── PayTech Sénégal ────────────────────────────────
PAYTECH_API_KEY=            # Clé API fournie par PayTech
PAYTECH_API_SECRET=         # Secret API fournie par PayTech
PAYTECH_SANDBOX=false       # false en production
PAYTECH_SECRET=             # Secret HMAC webhook PayTech

# ─── Twilio SMS ─────────────────────────────────────
TWILIO_SID=                 # Account SID depuis console.twilio.com
TWILIO_TOKEN=               # Auth Token depuis console.twilio.com
TWILIO_FROM=+221XXXXXXXXX   # Numéro Twilio Sénégal

# ─── Mail (optionnel) ───────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@fitpass.sn
MAIL_FROM_NAME="FitPass Dakar"

# ─── 2FA ────────────────────────────────────────────
TWO_FACTOR_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
